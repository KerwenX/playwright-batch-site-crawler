{
  "_comment": "Ultra-high concurrency configuration for server environments with 1000+ sites",
  "input_urls_file": "input_urls.txt",
  "output_root": "crawl_output_high_concurrency",
  "chromium_executable_path": "",
  "log_level": "INFO",
  "log_to_file": true,
  "headless": true,
  "aggressive_same_site_crawl": true,
  "worker_process_count": 4,
  "max_concurrency": 16,
  "max_site_concurrency": 4,
  "max_heavy_page_concurrency": 16,
  "max_light_page_concurrency": 16,
  "max_pages_per_session": 0,
  "max_api_expansion_concurrency": 8,
  "page_timeout_ms": 25000,
  "settle_ms": 800,
  "heavy_page_settle_ms": 1200,
  "light_page_settle_ms": 400,
  "response_grace_ms": 1000,
  "transient_page_retry_limit": 2,
  "max_pages_per_site": 0,
  "checkpoint_every_pages": 20,
  "checkpoint_every_seconds": 60,
  "write_full_outputs_on_checkpoint": false,
  "skip_completed_sites": true,
  "visit_leaf_pages": true,
  "include_site_homepage_seed": true,
  "enable_generic_interactions": true,
  "max_interaction_clicks_per_page": 30,
  "enable_cbpt_portal_ajax_expansion": true,
  "max_cbpt_portal_ajax_requests_per_page": 10,
  "max_api_pages_per_series": 0,
  "enable_waf_slider_solver": true,
  "max_waf_slider_attempts": 8,
  "waf_slider_candidate_count": 4,
  "playwright_driver_pool_size": 2,
  "session_rebuild_retries": 3,
  "session_failure_threshold": 3,
  "session_cooldown_seconds": 10,
  "proxy_servers": [],
  "proxy_session_count": 0,
  "skip_failed_proxies": true,
  "browser_launch_args": [
    "--disable-blink-features=AutomationControlled",
    "--disable-gpu",
    "--disable-dev-shm-usage",
    "--incognito",
    "--disable-background-networking",
    "--disable-default-apps",
    "--disable-extensions",
    "--disable-sync",
    "--disable-translate",
    "--metrics-recording-only",
    "--mute-audio",
    "--no-first-run",
    "--safebrowsing-disable-auto-update"
  ],
  "enable_request_blocking": true,
  "blocked_resource_types": [
    "image",
    "media",
    "font",
    "ping"
  ],
  "blocked_url_suffixes": [
    ".bmp",
    ".eot",
    ".gif",
    ".ico",
    ".jpeg",
    ".jpg",
    ".m4s",
    ".mp3",
    ".mp4",
    ".pdf",
    ".png",
    ".ppt",
    ".pptx",
    ".svg",
    ".ttf",
    ".wav",
    ".webm",
    ".webp",
    ".woff",
    ".woff2",
    ".doc",
    ".docx",
    ".xls",
    ".xlsx",
    ".zip",
    ".rar"
  ]
}