{
  "input_urls_file": "input_urls.txt",
  "output_root": "crawl_output_batch",
  "chromium_executable_path": "",
  "log_level": "INFO",
  "log_to_file": true,
  "headless": true,
  "aggressive_same_site_crawl": true,
  "max_concurrency": 8,
  "max_site_concurrency": 1,
  "max_heavy_page_concurrency": 8,
  "max_light_page_concurrency": 8,
  "max_pages_per_session": 0,
  "max_api_expansion_concurrency": 8,
  "page_timeout_ms": 20000,
  "settle_ms": 900,
  "heavy_page_settle_ms": 1500,
  "light_page_settle_ms": 500,
  "response_grace_ms": 1200,
  "transient_page_retry_limit": 1,
  "max_pages_per_site": 0,
  "checkpoint_every_pages": 10,
  "checkpoint_every_seconds": 30,
  "write_full_outputs_on_checkpoint": true,
  "skip_completed_sites": true,
  "visit_leaf_pages": true,
  "include_site_homepage_seed": true,
  "enable_generic_interactions": true,
  "max_interaction_clicks_per_page": 40,
  "enable_cbpt_portal_ajax_expansion": true,
  "max_cbpt_portal_ajax_requests_per_page": 12,
  "max_api_pages_per_series": 0,
  "enable_waf_slider_solver": true,
  "max_waf_slider_attempts": 12,
  "waf_slider_candidate_count": 5,
  "playwright_driver_pool_size": 1,
  "session_rebuild_retries": 1,
  "session_failure_threshold": 2,
  "session_cooldown_seconds": 30,
  "proxy_servers": [],
  "proxy_session_count": 0,
  "skip_failed_proxies": true,
  "browser_launch_args": [
    "--disable-blink-features=AutomationControlled",
    "--disable-gpu",
    "--disable-dev-shm-usage",
    "--incognito"
  ],
  "enable_request_blocking": true,
  "blocked_resource_types": [
    "image",
    "media",
    "font",
    "ping"
  ],
  "blocked_url_suffixes": [
    ".bmp",
    ".eot",
    ".gif",
    ".ico",
    ".jpeg",
    ".jpg",
    ".m4s",
    ".mp3",
    ".mp4",
    ".pdf",
    ".png",
    ".ppt",
    ".pptx",
    ".svg",
    ".ttf",
    ".wav",
    ".webm",
    ".webp",
    ".woff",
    ".woff2",
    ".doc",
    ".docx",
    ".xls",
    ".xlsx",
    ".zip",
    ".rar"
  ]
}
