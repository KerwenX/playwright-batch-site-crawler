{
  "input_urls_file": "input_urls.txt",
  "output_root": "/opt/huawei/data2/w00943222/spider/output",
  "chromium_executable_path": "",
  "log_level": "INFO",
  "log_to_file": true,
  "headless": true,
  "max_concurrency": 12,
  "max_site_concurrency": 4,
  "page_timeout_ms": 30000,
  "settle_ms": 1500,
  "max_pages_per_site": 0,
  "checkpoint_every_pages": 100,
  "checkpoint_every_seconds": 180,
  "write_full_outputs_on_checkpoint": false,
  "skip_completed_sites": true,
  "visit_leaf_pages": true,
  "include_site_homepage_seed": true,
  "enable_generic_interactions": true,
  "max_interaction_clicks_per_page": 18,
  "enable_cbpt_portal_ajax_expansion": true,
  "max_cbpt_portal_ajax_requests_per_page": 16,
  "max_api_pages_per_series": 0,
  "proxy_session_count": 12,
  "skip_failed_proxies": true,
  "proxy_servers": [
    "http://proxy-ip-1:port",
    "http://proxy-ip-2:port",
    {
      "server": "http://proxy-ip-3:port",
      "username": "optional-user",
      "password": "optional-password",
      "label": "proxy-3"
    }
  ],
  "browser_launch_args": [
    "--disable-blink-features=AutomationControlled",
    "--disable-gpu",
    "--disable-dev-shm-usage",
    "--incognito",
    "--no-sandbox",
    "--disable-setuid-sandbox"
  ],
  "enable_request_blocking": true,
  "blocked_resource_types": [
    "image",
    "media",
    "font",
    "ping"
  ],
  "blocked_url_suffixes": [
    ".m4s",
    ".jpg",
    ".jpeg",
    ".png",
    ".gif",
    ".bmp",
    ".webp",
    ".svg",
    ".ico",
    ".woff",
    ".woff2",
    ".ttf"
  ]
}
